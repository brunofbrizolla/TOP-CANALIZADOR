---
import Layout from '../layouts/Layout.astro';

// Serviço: Deteção de Fugas de Água

import Section8 from '../components/Section8.astro';
import Section9 from '../components/Section9.astro';
import Section10 from '../components/Section10.astro';
import Section11 from '../components/Section11.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import HowItWorks from '../components/HowItWorks.astro';

import background_heating_07Img from '../assets/images/background_heating_07.jpg';
import background_heating_07Img_1 from '../assets/images/background_heating_07.jpg';
import background_heating_07Img_2 from '../assets/images/background_heating_07.jpg';
---

<Layout 
  title="Deteção de Fugas - Top Canalizador"
  bodyClass="wp-singular page-template-default page page-id-1379 wp-theme-prohauz bt_bb_plugin_active btStickyEnabled btLightSkin btBelowMenu btNoDashInSidebar noBodyPreloader btSoftRoundedButtons btOpacityLightHeader btNoSidebar"
>
  
      <div class="btContentWrap btClear">
      <div class="btContentHolder">
        <div class="btContent">
          <div class="bt_bb_wrapper">

  <!-- Hero Section (ADJUSTED FOR HEADER OVERLAP & SYNCED BUTTON) -->
  <section class="bt_bb_section service-hero-section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_image" style={`background-image: url(${background_heating_07Img.src}); background-position: center; background-size: cover; position: relative;`}>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(12, 28, 44, 0.8), rgba(12, 28, 44, 0.4)); z-index: 0;"></div>
    <div class="bt_bb_port" style="position: relative; z-index: 1;">
        <div class="bt_bb_cell">
            <div class="bt_bb_cell_inner">
                <div class="bt_bb_row">
                    <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                        <div class="bt_bb_column_content">
                            <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_huge bt_bb_align_center">
                                <h1><span class="bt_bb_headline_content" style="color: #fff; font-weight: 900; font-size: 58px; text-transform: uppercase; letter-spacing: -2px; text-shadow: 0 4px 20px rgba(0,0,0,0.6);">DETEÇÃO DE <b style="color: #51acfb;">FUGAS</b></span></h1>

                            </header>
                            <div class="bt_bb_separator bt_bb_border_style_none" style="height: 40px;"></div>
                            
                            <!-- Homepage Standard Button Replication -->
                            <div class="bt_bb_button bt_bb_color_scheme_10 bt_bb_icon_position_left bt_bb_style_filled bt_bb_size_large bt_bb_width_inline bt_bb_shape_inherit bt_bb_target_self bt_bb_align_center" style="--primary-color:#ffffff; --secondary-color:#ef4c37;">
                                <a href="tel:+351969146836" target="_self" class="bt_bb_link" title="LIGAR AGORA">
                                    <span class="bt_bb_button_text">LIGAR AGORA: 969 146 836</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Feature Boxes Overlapping Hero -->
  <section class="bt_bb_section overlap-top">
    <div class="bt_bb_port">
      <div class="bt_bb_cell">
        <div class="bt_bb_cell_inner">
          <div class="service-grid-container">
            
            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Deteção sem Destruição</h3>
              <p>Localização da fuga feita com precisão térmica e acústica. Encontramos a origem sem abrir paredes.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Infiltrações nas Paredes</h3>
              <p>Diagnosticamos a causa real da humidade antes de qualquer intervenção, evitando danos estruturais.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Fugas em Canalização</h3>
              <p>Localizamos e reparamos fugas em tubagens ocultas com extrema qualidade e garantia de serviço.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Laudos e Peritagens</h3>
              <p>Emitimos relatórios detalhados com parecer de especialista para seguros e condomínios.</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Problemas que Resolvemos Section -->
  <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_large bt_bb_top_spacing_medium" style="background-color: #f7f9fa; padding: 100px 0;">
      <div class="bt_bb_port">
          <div class="bt_bb_cell">
              <div class="bt_bb_cell_inner">
                  <!-- Section Header -->
                  <div class="bt_bb_row">
                      <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                          <header class="bt_bb_headline bt_bb_dash_none bt_bb_superheadline bt_bb_size_large bt_bb_align_center">
                              <h3>
                                  <span class="bt_bb_headline_superheadline" style="color: #51acfb; font-weight: 700; letter-spacing: 2px;">SEJA QUAL FOR A FUGA, TEMOS A SOLUÇÃO.</span>
                                  <span class="bt_bb_headline_content"><span>Problemas que <b>Resolvemos</b></span></span>
                              </h3>
                          </header>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_large"></div>
                      </div>
                  </div>

                  <!-- 3 Columns Layout -->
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 1 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA NO CONTADOR</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">A água continua a correr mesmo com tudo fechado? O contador a girar é sinal de fuga oculta. Localizamos e resolvemos sem obras desnecessárias.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 2 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA NO PAVIMENTO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Humidade no chão, manchas a aparecer ou som de água a correr por baixo? Detetamos a tubagem afetada com equipamento de precisão, sem levantar o pavimento.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 3 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA NAS PAREDES</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Manchas de humidade, tinta a descascar ou bolor a aparecer? A causa pode ser tubagem embutida com fuga. Identificamos a origem exata antes de intervir.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>
                  
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 4 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA NA CASA DE BANHO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Sanita, base de duche ou banheira com perda de água? Inspecionamos vedações, juntas e ligações e resolvemos no próprio dia.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 5 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA NA COZINHA</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Água por baixo do lava-loiça, humidade no móvel ou chão molhado sem razão aparente? Verificamos toda a instalação e reparamos na hora.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 6 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGA EXTERIOR</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Jardim encharcado, consumo elevado sem explicação? Detetamos fugas em tubagens enterradas e redes de rega sem escavar desnecessariamente.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>

              </div>
          </div>
      </div>
  </section>


  
  <HowItWorks />
  <Section8 />
  <Section9 />
  <Section10 />
  <Section11 />
  <WhoWeAre />

          </div>
        </div>
      </div>
    </div>
  </Layout>
