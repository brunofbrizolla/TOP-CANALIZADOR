---
import Layout from '../layouts/Layout.astro';

// Serviço: Limpeza de Fossas (Automated Page Generation)

import Section8 from '../components/Section8.astro';
import Section9 from '../components/Section9.astro';
import Section10 from '../components/Section10.astro';
import Section11 from '../components/Section11.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import HowItWorks from '../components/HowItWorks.astro';
import inner_service_02Img from '../assets/images/inner_service_02.jpg';
---

<Layout 
  title="Limpeza de Fossas - Top Canalizador"
  bodyClass="wp-singular page-template-default page page-id-1379 wp-theme-prohauz bt_bb_plugin_active btStickyEnabled btLightSkin btBelowMenu btNoDashInSidebar noBodyPreloader btSoftRoundedButtons btOpacityLightHeader btNoSidebar"
>
  
      <div class="btContentWrap btClear">
      <div class="btContentHolder">
        <div class="btContent">
          <div class="bt_bb_wrapper">

  <!-- Hero Section -->
  <section class="bt_bb_section service-hero-section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_image" style={`background-image: url(${inner_service_02Img.src}); background-position: center; background-size: cover; position: relative;`}>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(12, 28, 44, 0.8), rgba(12, 28, 44, 0.4)); z-index: 0;"></div>
    <div class="bt_bb_port" style="position: relative; z-index: 1;">
        <div class="bt_bb_cell">
            <div class="bt_bb_cell_inner">
                <div class="bt_bb_row">
                    <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                        <div class="bt_bb_column_content">
                            <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_huge bt_bb_align_center">
                                <h1><span class="bt_bb_headline_content" style="color: #fff; font-weight: 900; font-size: 58px; text-transform: uppercase; letter-spacing: -2px; text-shadow: 0 4px 20px rgba(0,0,0,0.6);">LIMPEZA DE <b style='color: #51acfb;'>FOSSAS</b></span></h1>

                            </header>
                            <div class="bt_bb_separator bt_bb_border_style_none" style="height: 40px;"></div>
                            
                            <!-- Homepage Standard Button Replication -->
                            <div class="bt_bb_button bt_bb_color_scheme_10 bt_bb_icon_position_left bt_bb_style_filled bt_bb_size_large bt_bb_width_inline bt_bb_shape_inherit bt_bb_target_self bt_bb_align_center" style="--primary-color:#ffffff; --secondary-color:#ef4c37;">
                                <a href="tel:+351969146836" target="_self" class="bt_bb_link" title="LIGAR AGORA">
                                    <span class="bt_bb_button_text">LIGAR AGORA: 969 146 836</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Feature Boxes Overlapping Hero -->
  <section class="bt_bb_section overlap-top">
    <div class="bt_bb_port">
      <div class="bt_bb_cell">
        <div class="bt_bb_cell_inner">
          <div class="service-grid-container">
            
            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Frota Especializada</h3>
              <p>Veículos perfeitamente adaptados para aspiração a vácuo, quer se trate de esvaziamento total ou parcial.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Caixas de Gordura</h3>
              <p>Intervenção rigorosa no setor alimentar com esvaziamento de separadores e emissão de relatórios legais.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Destino Autorizado</h3>
              <p>Respeito pelo ambiente, encaminhando todos os resíduos transportados para centros de tratamento aprovados.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Manutenção Periódica</h3>
              <p>Contratos de manutenção para assegurar a funcionalidade constante e evitar maus odores duradouros.</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Problemas que Resolvemos Section -->
  <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_large bt_bb_top_spacing_medium" style="background-color: #f7f9fa; padding: 100px 0;">
      <div class="bt_bb_port">
          <div class="bt_bb_cell">
              <div class="bt_bb_cell_inner">
                  <!-- Section Header -->
                  <div class="bt_bb_row">
                      <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                          <header class="bt_bb_headline bt_bb_dash_none bt_bb_superheadline bt_bb_size_large bt_bb_align_center">
                              <h3>
                                  <span class="bt_bb_headline_superheadline" style="color: #51acfb; font-weight: 700; letter-spacing: 2px;">TUDO PARA UMA SOLUÇÃO DEFINITIVA</span>
                                  <span class="bt_bb_headline_content"><span>Onde nós <b>Atuamos</b></span></span>
                              </h3>
                          </header>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_large"></div>
                      </div>
                  </div>

                  <!-- 3 Columns Layout -->
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 1 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FOSSA SÉPTICA CHEIA</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Nível no topo e água das casas de banho a recuar. Esvaziamos totalmente a fossa séptica restaurando de seguida a drenagem normal.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 2 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">INUNDAÇÃO NA PROPRIEDADE</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Os derrames espalharam e criaram graves constrangimentos ambientais e sanitários? Realizamos a remoção rigorosa.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 3 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">POÇO ABSORVENTE BLOQUEADO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">O poço perdeu capacidade de infiltração. Nós utilizamos jatos de alta intensidade que quebram as barreiras minerais.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>
                  
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 4 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">CAIXAS INTERLIGAÇÃO AVERTIDAS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Entupimento nas vias entre saneamento municipal e particular. Atuamos com as espirais adequadas desbloqueando por completo.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 5 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">RESTAURANTES OBRIGADOS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">A rotina higiénica em caixas de gordura evita fecho por parte da ASAE. Efetuamos limpezas atempadas agendadas.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 6 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">OBSTRUÇÃO POR AREIAS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Acumulação anormal de pedras, entulho e lamas grossas removidas do interior da fossa usando bicos hidrodinâmicos fortíssimos.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>

              </div>
          </div>
      </div>
  </section>



  
  <HowItWorks />
  <Section8 />
  <Section9 />
  <Section10 />
  <Section11 />
  <WhoWeAre />

          </div>
        </div>
      </div>
    </div>
  </Layout>
