---
import Layout from '../layouts/Layout.astro';

// Serviço: Reparações & Manutenções (Automated Page Generation)

import Section8 from '../components/Section8.astro';
import Section9 from '../components/Section9.astro';
import Section10 from '../components/Section10.astro';
import Section11 from '../components/Section11.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import HowItWorks from '../components/HowItWorks.astro';

import inner_service_04Img from '../assets/images/inner_service_04.jpg';
import inner_service_04Img_1 from '../assets/images/inner_service_04.jpg';
import inner_service_04Img_2 from '../assets/images/inner_service_04.jpg';
---

<Layout 
  title="Reparações & Manutenções - Top Canalizador"
  bodyClass="wp-singular page-template-default page page-id-1379 wp-theme-prohauz bt_bb_plugin_active btStickyEnabled btLightSkin btBelowMenu btNoDashInSidebar noBodyPreloader btSoftRoundedButtons btOpacityLightHeader btNoSidebar"
>
  
      <div class="btContentWrap btClear">
      <div class="btContentHolder">
        <div class="btContent">
          <div class="bt_bb_wrapper">

  <!-- Hero Section -->
  <section class="bt_bb_section service-hero-section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_image" style="background-image: url('${inner_service_04Img.src}'); background-position: center; background-size: cover; position: relative;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(12, 28, 44, 0.8), rgba(12, 28, 44, 0.4)); z-index: 0;"></div>
    <div class="bt_bb_port" style="position: relative; z-index: 1;">
        <div class="bt_bb_cell">
            <div class="bt_bb_cell_inner">
                <div class="bt_bb_row">
                    <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                        <div class="bt_bb_column_content">
                            <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_huge bt_bb_align_center">
                                <h1><span class="bt_bb_headline_content" style="color: #fff; font-weight: 900; font-size: 58px; text-transform: uppercase; letter-spacing: -2px; text-shadow: 0 4px 20px rgba(0,0,0,0.6);">REPARAÇÕES <b style='color: #51acfb;'>GERAIS</b></span></h1>

                            </header>
                            <div class="bt_bb_separator bt_bb_border_style_none" style="height: 40px;"></div>
                            
                            <!-- Homepage Standard Button Replication -->
                            <div class="bt_bb_button bt_bb_color_scheme_10 bt_bb_icon_position_left bt_bb_style_filled bt_bb_size_large bt_bb_width_inline bt_bb_shape_inherit bt_bb_target_self bt_bb_align_center" style="--primary-color:#ffffff; --secondary-color:#ef4c37;">
                                <a href="tel:+351969146836" target="_self" class="bt_bb_link" title="LIGAR AGORA">
                                    <span class="bt_bb_button_text">LIGAR AGORA: 969 146 836</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Feature Boxes Overlapping Hero -->
  <section class="bt_bb_section overlap-top">
    <div class="bt_bb_port">
      <div class="bt_bb_cell">
        <div class="bt_bb_cell_inner">
          <div class="service-grid-container">
            
            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Intervenção Imediata</h3>
              <p>Técnicos disponíveis para deslocações rápidas nos principais centros urbanos, resolvendo as avarias na hora.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Diagnóstico Exato</h3>
              <p>A raiz das ocorrências é identificada com precisão, garantindo que apenas o necessário é reparado e protegido.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Cuidado Doméstico</h3>
              <p>Protegemos o seu ambiente isolando o ponto do problema a reparar, garantindo limpeza e integridade da casa.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Garantia Trabalho</h3>
              <p>Utilizamos acessórios e materiais homologados, aplicando sempre as respetivas garantias de fabricante.</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Problemas que Resolvemos Section -->
  <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_large bt_bb_top_spacing_medium" style="background-color: #f7f9fa; padding: 100px 0;">
      <div class="bt_bb_port">
          <div class="bt_bb_cell">
              <div class="bt_bb_cell_inner">
                  <!-- Section Header -->
                  <div class="bt_bb_row">
                      <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                          <header class="bt_bb_headline bt_bb_dash_none bt_bb_superheadline bt_bb_size_large bt_bb_align_center">
                              <h3>
                                  <span class="bt_bb_headline_superheadline" style="color: #51acfb; font-weight: 700; letter-spacing: 2px;">TUDO PARA UMA SOLUÇÃO DEFINITIVA</span>
                                  <span class="bt_bb_headline_content"><span>Onde nós <b>Atuamos</b></span></span>
                              </h3>
                          </header>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_large"></div>
                      </div>
                  </div>

                  <!-- 3 Columns Layout -->
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 1 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">MÁQUINAS A VERTER</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">A máquina de lavar deita água pelas tubagens? Alteração e re-instalações nas válvulas asseguram conexões seguras e permanentes.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 2 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">LOUÇA SANITÁRIA QUEBRADA</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">O lavatório apresenta rachaduras ou o reservatório vaza constantemente. Substituição a tempo é evitar de vez problemas custosos.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 3 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">SISTEMAS TERMO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">A água não atinge temperatura na saída? Reparação pontual ou troca de ligações corrompidas no esquentador/cilindro de águas quentes.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>
                  
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 4 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">QUEBRA NA PRESSÃO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">As torneiras deixaram de fornecer de forma natural porque acumularam calcário nos filtros. Solucionamos reavendo pressões perfeitas.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 5 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">PRUMADAS EXTERIORES</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Ruptura ou queda de secções por desgaste exterior à propriedade? Restauramos com material de tubagem mais contemporânea.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 6 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">LIGAÇÕES NA CAVE</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Reparações e manutenções intensas de todos os ramais das caves de prédios onde a humidade castiga o material preexistente original.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>

              </div>
          </div>
      </div>
  </section>


  <section id="bt_bb_section_cta" class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_color_scheme_1 bt_bb_bottom_spacing_huge bt_bb_top_spacing_huge">
    <div class="bt_bb_port">
        <div class="bt_bb_cell">
            <div class="bt_bb_cell_inner">
                <div class="bt_bb_row">
                    <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                        <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_large">
                            <h2><span class="bt_bb_headline_content"><span>Poupe dinheiro e evite estragos maiores! LIGUE-NOS JÁ!</span></span></h2>
                        </header>
                        <div class="bt_bb_separator bt_bb_border_style_none" style="height: 40px;"></div>
                            
                            <!-- Homepage Standard Button Replication -->
                            <div class="bt_bb_button bt_bb_style_filled bt_bb_size_medium bt_bb_shape_square bt_bb_color_scheme_7">
                            <a href="tel:969146836" target="_self" class="bt_bb_link"><span class="bt_bb_button_text">CHAMAR TÉCNICO AGORA</span></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  
  <HowItWorks />
  <Section8 />
  <Section9 />
  <Section10 />
  <Section11 />
  <WhoWeAre />

          </div>
        </div>
      </div>
    </div>
  </Layout>
