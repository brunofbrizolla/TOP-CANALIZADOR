---
import Layout from '../layouts/Layout.astro';

// Serviço: Canalização Comercial (Automated Page Generation)

import Section8 from '../components/Section8.astro';
import Section9 from '../components/Section9.astro';
import Section10 from '../components/Section10.astro';
import Section11 from '../components/Section11.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import HowItWorks from '../components/HowItWorks.astro';

import inner_service_02Img from '../assets/images/inner_service_02.jpg';
import inner_service_02Img_1 from '../assets/images/inner_service_02.jpg';
import inner_service_02Img_2 from '../assets/images/inner_service_02.jpg';
---

<Layout 
  title="Canalização Comercial - Top Canalizador"
  bodyClass="wp-singular page-template-default page page-id-1379 wp-theme-prohauz bt_bb_plugin_active btStickyEnabled btLightSkin btBelowMenu btNoDashInSidebar noBodyPreloader btSoftRoundedButtons btOpacityLightHeader btNoSidebar"
>
  
      <div class="btContentWrap btClear">
      <div class="btContentHolder">
        <div class="btContent">
          <div class="bt_bb_wrapper">

  <!-- Hero Section -->
  <section class="bt_bb_section service-hero-section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_image" style={`background-image: url(${inner_service_02Img.src}); background-position: center; background-size: cover; position: relative;`}>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(12, 28, 44, 0.8), rgba(12, 28, 44, 0.4)); z-index: 0;"></div>
    <div class="bt_bb_port" style="position: relative; z-index: 1;">
        <div class="bt_bb_cell">
            <div class="bt_bb_cell_inner">
                <div class="bt_bb_row">
                    <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                        <div class="bt_bb_column_content">
                            <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_huge bt_bb_align_center">
                                <h1><span class="bt_bb_headline_content" style="color: #fff; font-weight: 900; font-size: 58px; text-transform: uppercase; letter-spacing: -2px; text-shadow: 0 4px 20px rgba(0,0,0,0.6);">CANALIZAÇÃO <b style='color: #51acfb;'>COMERCIAL</b></span></h1>

                            </header>
                            <div class="bt_bb_separator bt_bb_border_style_none" style="height: 40px;"></div>
                            
                            <!-- Homepage Standard Button Replication -->
                            <div class="bt_bb_button bt_bb_color_scheme_10 bt_bb_icon_position_left bt_bb_style_filled bt_bb_size_large bt_bb_width_inline bt_bb_shape_inherit bt_bb_target_self bt_bb_align_center" style="--primary-color:#ffffff; --secondary-color:#ef4c37;">
                                <a href="tel:+351969146836" target="_self" class="bt_bb_link" title="LIGAR AGORA">
                                    <span class="bt_bb_button_text">LIGAR AGORA: 969 146 836</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Feature Boxes Overlapping Hero -->
  <section class="bt_bb_section overlap-top">
    <div class="bt_bb_port">
      <div class="bt_bb_cell">
        <div class="bt_bb_cell_inner">
          <div class="service-grid-container">
            
            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Manutenção Preventiva</h3>
              <p>Evite paragens no seu negócio. Realizamos inspeções e limpezas regulares para prevenir emergências dispendiosas.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Reparações Rápidas</h3>
              <p>Atuamos com a máxima urgência para minimizar o impacto em clientes e funcionários, restabelecendo o fluxo normal.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Novas Instalações</h3>
              <p>Projeto e execução de redes hidráulicas e sanitárias adequadas à exigência do seu espaço comercial.</p>
            </div>

            <div class="prof-service-box">
              <div class="icon-circle">
                <span data-ico-fontawesome=""></span>
              </div>
              <h3>Higiene e Segurança</h3>
              <p>Cumprimos rigorosamente com todas as normas de higiene e segurança, garantindo a salubridade das instalações.</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Problemas que Resolvemos Section -->
  <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_large bt_bb_top_spacing_medium" style="background-color: #f7f9fa; padding: 100px 0;">
      <div class="bt_bb_port">
          <div class="bt_bb_cell">
              <div class="bt_bb_cell_inner">
                  <!-- Section Header -->
                  <div class="bt_bb_row">
                      <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                          <header class="bt_bb_headline bt_bb_dash_none bt_bb_superheadline bt_bb_size_large bt_bb_align_center">
                              <h3>
                                  <span class="bt_bb_headline_superheadline" style="color: #51acfb; font-weight: 700; letter-spacing: 2px;">TUDO PARA UMA SOLUÇÃO DEFINITIVA</span>
                                  <span class="bt_bb_headline_content"><span>Onde nós <b>Atuamos</b></span></span>
                              </h3>
                          </header>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_large"></div>
                      </div>
                  </div>

                  <!-- 3 Columns Layout -->
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 1 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">WC PÚBLICO ENTUPIDO</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Sanitas e urinóis bloqueados devido a uso indevido são rapidamente desobstruídos com equipamento mecânico adequado.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 2 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">LAVA-LOIÇAS INDUSTRIAIS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Bancas entupidas por gorduras crónicas na hotelaria? Limpeza profunda com hidrojato de alta pressão (hidrolavagem).</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 3 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">ROTURAS NA REDE PRINCIPAL</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Tubagens de grande diâmetro com perda de pressão. Detetamos e resolvemos para não ter falhas de abastecimento.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>
                  
                  <div class="bt_bb_row bt_bb_column_gap_30">
                      <!-- Column 4 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">CAIXAS GORDURAS CHEIAS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Extração e esgotamento profissional de caixas separadoras de gorduras e fossas com veículos de aspiração.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 5 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">FUGAS OCULTAS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Aumento súbito da fatura comercial? Localização não destrutiva para identificar roturas em áreas extensas.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                      <!-- Column 6 -->
                      <div class="bt_bb_column col-xxl-4 col-xl-4 col-lg-4 col-md-6 col-sm-12 bt_bb_vertical_align_top bt_bb_align_left">
                          <div class="bt_bb_service bt_bb_color_scheme_1 bt_bb_style_borderless bt_bb_size_medium bt_bb_shape_circle bt_bb_align_inherit" style="--service-primary-color:#51acfb; background: #fff; padding: 40px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); border-radius: 8px; height: 100%;">
                              <span data-ico-fontawesome="" class="bt_bb_icon_holder" style="color:#51acfb;"></span>
                              <div class="bt_bb_service_content">
                                  <div class="bt_bb_service_content_title" style="font-size: 18px; margin-bottom: 15px; font-weight: 700;">RENOVAÇÃO DE PRUMADAS</div>
                                  <div class="bt_bb_service_content_text" style="color: #555; line-height: 1.6;">Substituição programada de prumadas envelhecidas sem necessidade de parar a atividade a longo prazo.</div>
                              </div>
                          </div>
                          <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                      </div>
                  </div>

              </div>
          </div>
      </div>
  </section>



  
  <HowItWorks />
  <Section8 />
  <Section9 />
  <Section10 />
  <Section11 />
  <WhoWeAre />

          </div>
        </div>
      </div>
    </div>
  </Layout>


