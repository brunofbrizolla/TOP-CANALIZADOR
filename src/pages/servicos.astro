---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

// Clone exato da página de Serviços baseada no HTML original
---

<Layout 
  title="TOP Canalizador - Os melhores serviços de Canalização do País!"
  description="Os melhores Serviços de Canalização particular, comercial e industrial, desentupimentos, limpeza de fossas e reparações 24h todos os dias do ano!"
  bodyClass="wp-singular page-template-default page page-id-1379 wp-theme-prohauz bt_bb_plugin_active btStickyEnabled btLightSkin btBelowMenu btNoDashInSidebar noBodyPreloader btSoftRoundedButtons btOpacityLightHeader btNoSidebar"
>
  <Header />

  <div class="btPageWrap" id="top">
    <div class="btContentWrap btClear">
      <div class="btContentHolder">
        <div class="btContent">
          <div class="bt_bb_wrapper">

  <main>
    <!-- HERO SECTION -->
    <section id="bt_bb_section_67b4946399049" class="bt_bb_section service-hero-section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_image bt_bb_background_overlay_gradient" style="background-image:url(https://topcanalizador.com/wp-content/uploads/2018/10/background_heating_07.jpg); --section-primary-color:#005299; --section-secondary-color:rgba(0,82,153,0);">
        <div class="bt_bb_port">
            <div class="bt_bb_cell">
                <div class="bt_bb_cell_inner">
                    <div class="bt_bb_row" data-structure="12">
                        <div class="bt_bb_column col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-xs-12 bt_bb_align_left bt_bb_vertical_align_top bt_bb_animation_fade_in animate">
                            <div class="bt_bb_column_content">
                                <div class="bt_bb_separator bt_bb_border_style_none bt_bb_top_spacing_huge"></div>
                                <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_huge bt_bb_align_inherit">
                                    <h3>
                                        <span class="bt_bb_headline_superheadline">CONHEÇA TUDO O QUE FAZEMOS</span>
                                        <span class="bt_bb_headline_content"><span>Os Nossos Serviços</span></span>
                                    </h3>
                                </header>
                                <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_huge"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SERVICES INTRO -->
    <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_large bt_bb_top_spacing_large">
        <div class="bt_bb_port">
            <div class="bt_bb_cell">
                <div class="bt_bb_cell_inner">
                    <div class="bt_bb_row">
                        <div class="bt_bb_column col-xxl-6 col-xl-6 bt_bb_animation_fade_in animate">
                             <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_large">
                                <h2><span class="bt_bb_headline_content"><span>Serviços de Canalização</span></span></h2>
                            </header>
                            <div class="bt_bb_text">
                                <p>Oferecemos uma vasta gama de serviços de canalização de alta qualidade, desde reparações de rotina a instalações complexas. A nossa equipa de técnicos qualificados está pronta para resolver qualquer problema com rapidez e eficiência.</p>
                                <ul>
                                    <li>Reparação de fugas de água</li>
                                    <li>Instalação de torneiras e acessórios</li>
                                    <li>Manutenção de sistemas de aquecimento</li>
                                    <li>Instalação de redes de água e esgotos</li>
                                </ul>
                            </div>
                        </div>
                        <div class="bt_bb_column col-xxl-6 col-xl-6 bt_bb_animation_fade_in animate">
                             <div class="bt_bb_image"><img src="https://topcanalizador.com/wp-content/uploads/2019/06/servicos-canalizacao.jpg" alt="Serviços de Canalização"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- GRID DE SERVIÇOS (Fiel ao original) -->
    <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_bottom_spacing_huge">
        <div class="bt_bb_port">
            <div class="bt_bb_cell">
                <div class="bt_bb_cell_inner">
                    <div class="bt_bb_row">
                        <!-- CANALIZADOR -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_1">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-tools=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Canalizador</div>
                                    <div class="bt_bb_service_content_text">Serviços gerais de canalização e reparações urgentes.</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                        <!-- DESENTUPIMENTOS -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_3">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-tools=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Desentupimentos</div>
                                    <div class="bt_bb_service_content_text">Desentupimento de canos, esgotos, sanitas e lava-loiças.</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                        <!-- LIMPEZA DE FOSSAS -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_5">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-tools=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Limpeza de Fossas</div>
                                    <div class="bt_bb_service_content_text">Aspiração e limpeza mecanizada de fossas sépticas.</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                        <!-- DETEÇÃO DE FUGAS -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_7">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-solar=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Deteção de Fugas</div>
                                    <div class="bt_bb_service_content_text">Deteção de fugas de água sem partir paredes (ultrassom).</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                        <!-- ASPIRAÇÃO DE INUNDAÇÕES -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_9">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-picons=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Inundações</div>
                                    <div class="bt_bb_service_content_text">Aspiração de águas em caves, garagens e poços de elevador.</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                        <!-- MONTAGEM DE LOUÇAS -->
                        <div class="bt_bb_column col-md-4 col-sm-6 bt_bb_animation_fade_in animate">
                            <div class="bt_bb_service bt_bb_style_filled bt_bb_size_medium bt_bb_shape_circle bt_bb_align_left bt_bb_color_scheme_11">
                                <span class="bt_bb_icon_holder"><span class="bt_bb_icon_inner" data-ico-tools=""></span></span>
                                <div class="bt_bb_service_content">
                                    <div class="bt_bb_service_content_title">Montagem de Louças</div>
                                    <div class="bt_bb_service_content_text">Instalação de sanitas, bidés, banheiras e polibãs.</div>
                                </div>
                            </div>
                            <div class="bt_bb_separator bt_bb_bottom_spacing_medium"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION CALL TO ACTION (Fiel ao original) -->
    <section class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_background_color_scheme_1 bt_bb_bottom_spacing_huge bt_bb_top_spacing_huge">
        <div class="bt_bb_port">
            <div class="bt_bb_cell">
                <div class="bt_bb_cell_inner">
                    <div class="bt_bb_row">
                        <div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_align_center">
                            <header class="bt_bb_headline bt_bb_dash_none bt_bb_size_large">
                                <h2><span class="bt_bb_headline_content"><span>Precisa de ajuda imediata? Ligue-nos 24h!</span></span></h2>
                            </header>
                            <div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_medium"></div>
                            <div class="bt_bb_button bt_bb_style_filled bt_bb_size_medium bt_bb_shape_square bt_bb_color_scheme_7">
                                <a href="tel:+351969146836" target="_self" class="bt_bb_link"><span class="bt_bb_button_text">CHAMAR TÉCNICO AGORA</span></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

  </main>

          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
  <CookieConsent />
</Layout>
