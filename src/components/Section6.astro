---
// Extracted and Fixed Section

import inner_04Img from '../assets/images/inner_04.jpg';
import inner_06Img from '../assets/images/inner_06.jpg';
import background_plumbing_01Img from '../assets/images/background_plumbing_01.jpg';
import inner_05Img from '../assets/images/inner_05.jpg';
import inner_04Img_1 from '../assets/images/inner_04.jpg';
import inner_06Img_1 from '../assets/images/inner_06.jpg';
import background_plumbing_01Img_1 from '../assets/images/background_plumbing_01.jpg';
import inner_05Img_1 from '../assets/images/inner_05.jpg';
import hero_desentupimentosImg from '../assets/images/hero-desentupimentos.png';
import inner_04Img_2 from '../assets/images/inner_04.jpg';
import inner_06Img_2 from '../assets/images/inner_06.jpg';
import background_plumbing_01Img_2 from '../assets/images/background_plumbing_01.jpg';
import inner_05Img_2 from '../assets/images/inner_05.jpg';
import hero_desentupimentosImg_1 from '../assets/images/hero-desentupimentos.png';
---
<style is:global>
  /* === OFERTA ESPECIAL BOXES FIX === */
  
  /* Make only the first row float up to overlap Section 5 */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) {
    margin-top: -150px !important; /* Perfect 150px overlap */
    position: relative;
    z-index: 50;
    margin-bottom: 20px !important;
  }

  /* Force exactly 3 columns side-by-side with no wrap and no gap - DESKTOP ONLY */
  @media (min-width: 992px) {
    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_row_holder {
      display: flex !important;
      flex-wrap: nowrap !important;
      width: 100%;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Each box - desktop 3 columns */
    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_column[data-width="4"] {
      flex: 1 1 33.333333% !important;
      max-width: 33.333333% !important;
      aspect-ratio: 1 / 1 !important;
      min-height: unset !important;
      padding: 0 !important;
      margin: 0 !important;
      background-size: cover !important;
      background-position: center !important;
      background-repeat: no-repeat !important;
      display: flex;
      flex-direction: column;
    }
  }

  /* MOBILE: Stack cards one below the other */
  @media (max-width: 991px) {
    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_row_holder {
      display: flex !important;
      flex-direction: column !important;
      flex-wrap: wrap !important;
      width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_column[data-width="4"] {
      flex: 0 0 100% !important;
      max-width: 100% !important;
      width: 100% !important;
      aspect-ratio: unset !important;
      min-height: 280px !important;
      padding: 0 !important;
      margin: 0 !important;
      background-size: cover !important;
      background-position: center !important;
      background-repeat: no-repeat !important;
      display: flex;
      flex-direction: column;
    }
  }

  /* Box content container */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_column_content {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
  }

  /* Inner content paddings */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_column_content_inner {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    padding: 40px 30px !important; /* Space inside the box */
    min-height: unset !important;
  }

  /* Fixed alignment for LIGUE JA buttons inside boxes */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_button {
    margin-top: auto !important;
    position: relative;
    z-index: 10;
  }
  
  /* Kill the enormous padding pushing the button up from the bottom of the picture */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_separator.bt_bb_bottom_spacing_large {
    display: none !important;
  }

  /* === EMPTY STATS ROW FIX === */
  /* Hide the useless empty row that was creating a massive invisible gap */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(2) {
    display: none !important;
  }

  /* === ROW 3: O QUE NÓS OFERECEMOS (24/7) === */

  /* Row 3 layout */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) {
    margin-top: 120px !important; /* Match the exact breathing room seen in the original website screenshot */
    margin-bottom: 60px !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_row_holder {
    display: flex !important;
    flex-wrap: wrap !important;
    align-items: flex-start !important; /* Ensure the Headline and Services align at the top uniformly */
    margin: 0 !important;
  }

  /* Drop trailing separators pushing vertical layouts */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_separator {
    display: none !important;
  }

  /* Target the Headline Block */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_headline_superheadline {
    display: block !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #666 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    margin-bottom: 20px !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_headline_content {
    display: block !important;
    font-size: 42px !important;
    line-height: 1.15 !important;
    font-weight: 800 !important;
    color: #252525 !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_headline_content b {
    color: #51acfb !important; /* The 24/7 is blue */
  }

  /* The 4 Services Grid setup */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_service {
    display: flex !important;
    align-items: flex-start !important;
    gap: 25px !important; /* Space between icon and text */
    margin-bottom: 40px !important;
    height: 180px !important; /* FORCES absolute equal column heights to align the bottom services perfectly, ignoring wrapping text heights */
  }

  /* Overriding WP circle icons to be simple outline icons like the reference */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_icon_holder {
    background: transparent !important;
    color: #51acfb !important;
    font-size: 44px !important; /* Nice large icon */
    width: auto !important;
    height: auto !important;
    line-height: 1 !important;
    border: none !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_icon_holder::before {
    background: transparent !important;
    box-shadow: none !important;
  }

  /* Service Text Content */
  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_service_content {
    display: block !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_service_content_title {
    font-size: 13px !important;
    font-weight: 800 !important;
    color: #252525 !important;
    margin-bottom: 15px !important;
    text-transform: uppercase !important;
    line-height: 1.4 !important;
  }

  #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_service_content_text {
    font-size: 14px !important;
    color: #555 !important;
    line-height: 1.6 !important;
  }

  /* Responsive Fixes Section 6 */
  @media (max-width: 991px) {
    /* 1. Stack the special offers squares */
    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) {
        margin-top: -80px !important; /* Smaller overlap on mobile */
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_row_holder {
        flex-direction: column !important;
        flex-wrap: wrap !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(1) .bt_bb_column[data-width="4"] {
        flex: 1 1 100% !important;
        max-width: 100% !important;
        aspect-ratio: unset !important;
        min-height: 350px !important;
    }

    /* 2. Fix the 24/7 services grid on mobile */
    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) {
        margin-top: 0px !important;
        margin-bottom: 0px !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_column {
        flex: 1 1 100% !important;
        max-width: 100% !important;
        padding: 0 !important;
        margin-bottom: 0px !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_headline_content {
        font-size: 32px !important;
        text-align: center !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_headline_superheadline {
        text-align: center !important;
        margin-top: 0 !important;
    }

    #bt_bb_section69e3d26039b28 > .bt_bb_port > .bt_bb_cell > .bt_bb_cell_inner > .bt_bb_row:nth-child(3) .bt_bb_service {
        height: auto !important;
        flex-direction: column !important;
        align-items: center !important;
        text-align: center !important;
        margin-bottom: 20px !important;
    }
  }

  /* === MOBILE OFERTA ESPECIAL: Hide WP version, show clean version === */
  @media (max-width: 991px) {
    /* Hide the original WP row with the 3 cards */
    .tc-oferta-wp-row {
      display: none !important;
    }

    /* Mobile clean version */
    .tc-oferta-mobile {
      display: flex !important;
      flex-direction: column !important;
      width: 100% !important;
      margin-top: -80px !important;
      position: relative;
      z-index: 50;
      gap: 0 !important;
    }

    .tc-oferta-mobile-card {
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-end !important;
      width: 100% !important;
      min-height: 280px !important;
      background-size: cover !important;
      background-position: center !important;
      padding: 30px 25px !important;
      box-sizing: border-box !important;
      position: relative;
    }

    .tc-oferta-mobile-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 70%);
    }

    .tc-oferta-mobile-card-content {
      position: relative;
      z-index: 1;
    }

    .tc-oferta-mobile-label {
      font-size: 11px !important;
      font-weight: 700 !important;
      color: #51acfb !important;
      letter-spacing: 2px !important;
      text-transform: uppercase !important;
      display: block !important;
      margin-bottom: 8px !important;
    }

    .tc-oferta-mobile-title {
      font-size: 28px !important;
      font-weight: 700 !important;
      color: #ffffff !important;
      line-height: 1.2 !important;
      margin: 0 0 20px 0 !important;
    }

    .tc-oferta-mobile-title b {
      color: #51acfb !important;
    }

    .tc-oferta-mobile-btn {
      display: inline-block !important;
      background: #ef4c37 !important;
      color: #ffffff !important;
      padding: 12px 28px !important;
      font-size: 13px !important;
      font-weight: 700 !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      letter-spacing: 1px !important;
      border-radius: 3px !important;
    }
  }

  @media (min-width: 992px) {
    .tc-oferta-mobile {
      display: none !important;
    }
  }
</style>

