---
// Extracted and Fixed Section
---
  <style is:global>
    /* === FIX ARRANJE VOCE MESMO TWO-COLUMN LAYOUT === */
    /* Force the Row Holder to display the two columns side by side, preventing the video from wrapping below the list */
    #bt_bb_section69e3d2603cc28 .bt_bb_row:nth-child(2) > .bt_bb_row_holder {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      align-items: center !important;
      gap: 50px !important;
      width: 100% !important;
    }

    /* Force columns to split exactly 50/50 */
    #bt_bb_section69e3d2603cc28 .bt_bb_row:nth-child(2) > .bt_bb_row_holder > .bt_bb_column {
      flex: 1 1 50% !important;
      width: 50% !important;
      max-width: 50% !important;
    }

    /* === FIX ARRANJE VOCE MESMO ACCORDION === */
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion {
      box-shadow: 0px 5px 25px rgba(0,0,0,0.08) !important;
      background: #fff !important;
      display: flex !important;
      flex-direction: column !important;
      padding: 0 !important;
      margin: 0 !important;
      width: 100% !important;
    }

    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item {
      display: flex !important;
      flex-direction: row !important; /* Force side-by-side */
      flex-wrap: wrap !important; /* CRITICAL: Allow content to wrap to next row */
      align-items: stretch !important;
      border-bottom: 1px solid #eee !important;
      border-top: none !important;
      border-left: none !important;
      border-right: none !important;
      margin: 0 !important; /* Remove gaps between cards */
      padding: 0 !important;
      cursor: pointer !important;
      transition: background 0.3s;
      min-height: 60px !important; /* Fixed flat height */
      background: #fff !important;
      box-shadow: none !important;
    }
    
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item:last-child {
      border-bottom: none !important;
    }

    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item_number {
      width: 60px !important;
      min-width: 60px !important;
      max-width: 60px !important;
      background: #f2f2f2 !important;
      color: #333 !important;
      font-weight: 800 !important;
      font-size: 15px !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      flex-shrink: 0 !important;
      height: auto !important; /* Stretch to fill parent */
      margin: 0 !important;
      padding: 0 !important;
      position: static !important;
    }

    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item_title {
      flex: 1 !important;
      min-width: calc(100% - 60px) !important;
      padding: 0 20px !important;
      font-size: 15px !important;
      font-weight: 700 !important;
      color: #333 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: space-between !important;
      background: transparent !important;
      margin: 0 !important;
      position: static !important;
      min-height: 60px !important;
    }

    /* Add the subtle '+' icon */
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item_title::after {
      content: '+' !important;
      font-size: 20px !important;
      font-weight: 500 !important;
      color: #aaa !important;
      margin-left: 10px !important;
    }

    /* Active state for icon */
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item.open .bt_bb_accordion_item_title::after {
      content: '-' !important;
      color: #51acfb !important;
    }

    /* Format text content to drop below */
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item_content {
      display: none !important; /* Hidden by default */
      width: 100% !important; /* Take full width on new line */
      padding: 20px 20px 20px 80px !important; /* Indent to align with title text */
      font-size: 14px !important;
      color: #666 !important;
      line-height: 1.6 !important;
      background: #fafafa !important;
      border-top: 1px solid #eee !important;
    }

    /* Show when open */
    #bt_bb_section69e3d2603cc28 .bt_bb_accordion_item.open .bt_bb_accordion_item_content {
      display: block !important;
    }
    
    /* Title Formatting */
    #bt_bb_section69e3d2603cc28 .bt_bb_headline_superheadline {
      font-size: 13px !important;
      font-weight: 700 !important;
      color: #666 !important;
      text-transform: uppercase !important;
      margin-bottom: 5px !important;
      display: block !important;
    }

    #bt_bb_section69e3d2603cc28 .bt_bb_headline_content {
      font-size: 42px !important;
      font-weight: 800 !important;
      color: #333 !important;
    }

    #bt_bb_section69e3d2603cc28 .bt_bb_headline_content b {
      color: #51acfb !important;
    }

    /* Fix the background image (the floating pipes on the left edge) */
    #bt_bb_section69e3d2603cc28 .bt_bb_background_image_holder {
      background-size: auto 100% !important; 
      background-position: left center !important;
      background-repeat: no-repeat !important;
      opacity: 1 !important;
      left: -80px !important;
    }

    /* Video Container Fix */
    #bt_bb_section69e3d2603cc28 .bt-video-container {
      position: relative !important;
      width: 100% !important;
      padding-bottom: 56.25% !important; /* 16:9 ratio via padding */
      height: 0 !important;
      background: #000 !important;
      overflow: hidden !important;
      box-shadow: 0px 10px 30px rgba(0,0,0,0.1) !important;
      border-radius: 4px !important;
    }
    
    #bt_bb_section69e3d2603cc28 .bt-video-container iframe {
      display: block !important;
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      border: 0 !important;
    }

    /* Hide entire section on mobile as requested by user */
    @media (max-width: 991px) {
      #bt_bb_section69e3d2603cc28 {
        display: none !important;
      }
    }
  </style>

<section id="bt_bb_section69e3d2603cc28" class="bt_bb_section bt_bb_layout_boxed_1200 bt_bb_vertical_align_top bt_bb_top_spacing_medium bt_bb_bottom_spacing_large" data-bt-override-class="null"><div class="bt_bb_background_image_holder_wrapper"><div style="background-image: url('/wp-content/uploads/2019/06/_wp-content_uploads_2018_09_background_plumbing_02.jpg') !important;" class="bt_bb_background_image_holder"></div></div><div class="bt_bb_port"><div class="bt_bb_cell"><div class="bt_bb_cell_inner"><div class="bt_bb_row" data-bt-override-class="{}"><div class="bt_bb_row_holder"><div class="bt_bb_column col-xxl-12 col-xl-12 bt_bb_vertical_align_top bt_bb_align_left bt_bb_padding_normal bt_bb_animation_fade_in animate" style="; --column-width:12;" data-width="12" data-bt-override-class="{}"><div class="bt_bb_column_content"><div class="bt_bb_column_content_inner"><header class="bt_bb_headline bt_bb_dash_none bt_bb_superheadline bt_bb_size_large bt_bb_align_inherit" data-bt-override-class="null"><h3><span class="bt_bb_headline_superheadline">ARRANJE VOCÊ MESMO</span><span class="bt_bb_headline_content"><span>Dicas <b>simples &amp; úteis</b></span></span></h3></header><div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_normal" data-bt-override-class="null"></div></div></div></div></div></div><div class="bt_bb_row" data-bt-override-class="{}"><div class="bt_bb_row_holder"><div class="bt_bb_column col-xxl-6 col-xl-6 bt_bb_vertical_align_middle bt_bb_align_left bt_bb_padding_normal bt_bb_animation_fade_in animate" style="; --column-width:6;" data-width="6" data-bt-override-class="{}"><div class="bt_bb_column_content"><div class="bt_bb_column_content_inner"><div class="bt_bb_accordion bt_bb_color_scheme_14 bt_bb_style_filled bt_bb_shape_square" style="; --accordion-primary-color:#ffffff; --accordion-secondary-color:#D0D0D0;" data-closed="closed"><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">1</div><div class="bt_bb_accordion_item_title">Utilize vinagre para evitar maus odores.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Ter maus odores em casa é das coisas mais desconfortáveis que podemos enfrentar! A verdade, é que existem vários motivos que podem provocar o aparecimento de maus odores nos canos, como aqueles canos que permanecem muito tempo fechados ou restos de comida que ficam presos.</p> <p>Mas não fique preocupado! Sabemos de um bom truque para eliminá-los! Apenas precisa de 200 ml de vinagre, meio litro de água e 100 gr de bicarbonato, fazer uma mistura destes três ingredientes e colocar no ralo. Depois só tem de verter água a ferver passados 30 minutos e já está!</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">2</div><div class="bt_bb_accordion_item_title">Desentupa canos com um desentupidor de borracha.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Acha que é assim tão difícil desentupir os canos? Não é! Veja como! Em primeiro lugar tem que usar o típico desentupidor de borracha. Deve utilizar também um pano e selar a parte de cima do lava-louça, o chamado “respiradouro”, por onde a água sai, no caso de encher de maneira excessiva.</p> <p>Agite o desentupidor para cima e para baixo, em movimentos repetitivos. Se voltar a fluir água, é recomendável verter uma panela de água a ferver com sal para diluir o que ficou nas paredes dos canos. O melhor é mesmo deixar água a ferver com sal durante toda a noite, uma vez que faz mais efeito!</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">3</div><div class="bt_bb_accordion_item_title">Use um aspirador para retirar objectos difíceis.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Nem sempre são apenas restos de comida que entopem os canos… Por vezes, nas sanitas, vão lá parar escovas de dentes, pentes ou mesmo brinquedos. E para esse tipo de objectos um desentupidor não é suficiente; às vezes até fazem pior, porque os empurram ainda mais para o fundo!</p> <p>Porque não utilizar um aspirador para os retirar? Ainda não experimentou? Do que está à espera?</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">4</div><div class="bt_bb_accordion_item_title">Elimine calcario nas máquinas de lavar-a-roupa/loiça.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>O calcário é outro dos problemas comuns em entupimentos. Sabe qual a maneira mais fácil de a evitar? Deve, pelo menos uma vez por mês, fazer uma programação de longa duração e a altas temperaturas, com a máquina vazia e substituindo o detergente por duas taças de vinagre.</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">5</div><div class="bt_bb_accordion_item_title">Seque os canos congelados.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Quando reparar que os seus canos estão congelados, o que pode utilizar é um secador de cabelo ou panos húmidos bem quentes. Tanto um como outro, ajudarão a que a temperatura dos canos comece a subir, mas lentamente. A ideia é que não se descongelem rapidamente, porque podem surgir danos ou rupturas nos canos e, consequemente, causar uma enorme inundação na sua casa.</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">6</div><div class="bt_bb_accordion_item_title">Evite ar nos canos.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Existem ocasiões em que podemos ouvir barulhos estranhos nos canos, sobretudo, em moradias que têm estado fechadas durante algum tempo ou em épocas longas em que a água foi cortada.</p> <p>Mas porque é que tal acontece? A principal razão deve-se ao facto de os canos terem colhido ar e ganharem bolhas. Para eliminá-las, a primeira opção é abrir todas as torneiras durante um ou dois minutos e deixar que a água volte a correr normalmente.</p> <p>Caso o problema se mantenha, aumente a pressão da água colocando uma mangueira na torneira e abra duas torneiras ao mesmo tempo para deixar que a água circule e a pressão arraste as bolhas de ar para fora.</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">7</div><div class="bt_bb_accordion_item_title">Purifique os esquentadores.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>Da mesma maneira que os canos ganham bolhas de ar, os esquentadores também as podem ganhar durante o tempo em que não são utilizados. Caso isto aconteça, leva a que não aqueçam e a que façam barulhos esquisitos! A maneira mais fácil de solucionar este problema é, ao estar ligada a caldeira, desenroscar a válvula de evacuação para que o ar saia e a água comece a sair.</p></div></div></div><div class="bt_bb_accordion_item"><div class="bt_bb_accordion_item_number">8</div><div class="bt_bb_accordion_item_title">Arrange uma torneira que está constantemente a pingar.</div><div class="bt_bb_accordion_item_content"><div class="bt_bb_text"> <p>É muito comum encontrarmos uma torneira que não fecha bem e, por isso, está sucessivamente a pingar. Para além do desconforto do barulho, o desperdício de água é enorme… Mas sabe que a causa é muito simples? Ou a torneira tem alguma peça partida, ou está gasta ou mesmo suja.</p> <p>Aquilo que sugerimos que faça é desmontar todas as peças da torneira e limpá-las de forma adequada, mas tenha imenso cuidado com as peças, porque se perde alguma, vai acabar num contratempo!</p></div></div></div></div><div class="bt_bb_separator bt_bb_border_style_none bt_bb_bottom_spacing_normal bt_bb_hidden_md bt_bb_hidden_lg" data-bt-override-class="null"></div></div></div></div><div class="bt_bb_column col-xxl-6 col-xl-6 bt_bb_vertical_align_middle bt_bb_align_left bt_bb_padding_normal bt_bb_animation_fade_in animate" style="; --column-width:6;" data-width="6" data-bt-override-class="{}"><div class="bt_bb_column_content"><div class="bt_bb_column_content_inner"><div class="bt_bb_text"><div class="bt-video-container"><iframe src="https://www.youtube.com/embed/QrD_oPhMVWs?modestbranding=1&rel=0" title="How to Fix Common Leaks | Basic Plumbing" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div></div></div></div></div></div></div></div></div></div></section>

<script is:inline>
  (function initAccordion() {
    const accordionItems = document.querySelectorAll("#bt_bb_section69e3d2603cc28 .bt_bb_accordion_item");
    if(!accordionItems || accordionItems.length === 0) return; // guard
    
    // Remove old listeners to prevent duplicates on HMR
    accordionItems.forEach(item => {
      const newClone = item.cloneNode(true);
      if(item.parentNode) item.parentNode.replaceChild(newClone, item);
    });

    const refreshedItems = document.querySelectorAll("#bt_bb_section69e3d2603cc28 .bt_bb_accordion_item");
    refreshedItems.forEach(item => {
      item.addEventListener("click", () => {
        const isOpen = item.classList.contains("open");
        refreshedItems.forEach(i => i.classList.remove("open"));
        if (!isOpen) {
          item.classList.add("open");
        }
      });
    });
  })();
</script>