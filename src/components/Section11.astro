---
// Section 11 - Nossos Números (Premium Branding)
---

<section id="our-numbers" class="stats-section">
  <!-- Decorative background elements -->
  <div class="bg-gradient"></div>
  <div class="bg-grid"></div>

  <div class="container">
    <div class="header-content">
      <h2 class="section-title">A nossa Empresa em <span class="highlight">números</span></h2>
      <p class="section-subtitle">O atendimento ao cliente não é uma técnica a ser implantada, mas sim uma postura a ser cultivada.</p>
    </div>

    <div class="stats-grid">
      <!-- Stat Item 1 -->
      <div class="stat-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="number-wrapper">
          <span class="count" data-target="2935">2935</span>
        </div>
        <span class="label">CLIENTES SATISFEITOS</span>
      </div>

      <!-- Stat Item 2 -->
      <div class="stat-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="number-wrapper">
          <span class="plus">+</span><span class="count" data-target="15">15</span>
        </div>
        <span class="label">ANOS DE EXPERIÊNCIA</span>
      </div>

      <!-- Stat Item 3 -->
      <div class="stat-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div class="number-wrapper">
          <span class="count" data-target="948">948</span>
        </div>
        <span class="label">INSTALAÇÕES</span>
      </div>

      <!-- Stat Item 4 -->
      <div class="stat-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div class="number-wrapper">
          <span class="count" data-target="750">750</span><span class="unit">KM</span>
        </div>
        <span class="label">KM DE TUBO</span>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    position: relative;
    padding: 100px 20px;
    background-color: #252525;
    color: #ffffff;
    overflow: hidden;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .bg-gradient {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(81, 172, 251, 0.15) 0%, transparent 70%);
    z-index: 1;
  }

  .bg-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: 2;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  .header-content {
    text-align: center;
    margin-bottom: 70px;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }

  .section-title .highlight {
    color: #51acfb;
    position: relative;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 40px 30px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-card:hover {
    transform: translateY(-10px);
    background: rgba(255, 255, 255, 0.05);
    border-color: #51acfb;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 20px rgba(81, 172, 251, 0.1);
  }

  .icon-wrapper {
    width: 70px;
    height: 70px;
    background: rgba(81, 172, 251, 0.1);
    color: #51acfb;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
    transition: all 0.3s ease;
  }

  .stat-card:hover .icon-wrapper {
    background: #51acfb;
    color: #ffffff;
    transform: rotate(10deg);
  }

  .number-wrapper {
    font-size: 3.5rem;
    font-weight: 900;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 15px;
    display: flex;
    align-items: baseline;
    gap: 5px;
  }

  .count {
    font-variant-numeric: tabular-nums;
  }

  .plus, .unit {
    color: #51acfb;
    font-size: 2.5rem;
  }

  .label {
    font-size: 0.9rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 2.2rem;
    }
    
    .stats-section {
      padding: 70px 20px;
    }

    .number-wrapper {
      font-size: 2.8rem;
    }
  }
</style>

<script is:inline>
  function animateCounters() {
    const statsSection = document.querySelector('#our-numbers');
    const counters = document.querySelectorAll('.count');
    const speed = 200;

    if (!statsSection) return;

    const startCounter = (counter) => {
      const target = +counter.getAttribute('data-target');
      const count = +counter.innerText;
      const increment = Math.ceil(target / speed);

      if (count < target) {
        counter.innerText = count + increment;
        setTimeout(() => startCounter(counter), 10);
      } else {
        counter.innerText = target;
      }
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (!statsSection.hasAttribute('data-animated')) {
            statsSection.setAttribute('data-animated', 'true');
            counters.forEach(counter => {
              counter.innerText = '0';
              startCounter(counter);
            });
          }
        }
      });
    }, { threshold: 0.1 });

    observer.observe(statsSection);
  }

  // Bind to events
  document.addEventListener('DOMContentLoaded', animateCounters);
  window.addEventListener('load', animateCounters);
  document.addEventListener('astro:after-swap', animateCounters);
</script>