---
// Section 9 - Seamless Marquee Brands Bar
---
<style>
  .brands-section-wrapper {
    background-color: #ffffff;
    position: relative;
    padding-bottom: 80px;
    z-index: 100;
  }
  
  .brands-bg-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(#d1d5db 1.2px, transparent 1.2px);
    background-size: 32px 32px;
    opacity: 0.5;
    z-index: 1;
  }

  .brands-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 10;
  }

  .brands-white-bar {
    background: #ffffff;
    border-radius: 8px;
    padding: 40px 20px;
    box-shadow: 0 25px 70px rgba(0,0,0,0.12);
    margin-top: -80px; 
    border: 1px solid rgba(0,0,0,0.05);
    overflow: hidden; /* Prevent logos from spilling outside */
    position: relative;
  }

  .marquee-wrapper {
    width: 100%;
    display: flex;
    overflow: hidden;
    position: relative;
  }

  /* Fade edges so logos appear and disappear smoothly */
  .marquee-wrapper::before,
  .marquee-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    width: 60px;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  
  .marquee-wrapper::before {
    left: 0;
    background: linear-gradient(to right, #ffffff 0%, rgba(255,255,255,0) 100%);
  }
  
  .marquee-wrapper::after {
    right: 0;
    background: linear-gradient(to left, #ffffff 0%, rgba(255,255,255,0) 100%);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 80px;
    width: max-content; /* Let it be as wide as it needs to be */
    animation: scroll-left 25s linear infinite;
  }

  /* Pause on hover */
  .marquee-track:hover {
    animation-play-state: paused;
  }

  .marquee-track img {
    height: 85px; /* Significantly larger base height */
    width: auto;
    max-width: none; /* No artificial width limits */
    object-fit: contain;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    cursor: auto;
  }

  .marquee-track img:hover {
    transform: scale(1.05);
  }

  /* The translation needs to precisely move exactly half of the track's width.
     Since we duplicated the elements exactly once, exactly half the width is exactly one set of logos. */
  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 40px)); } /* 40px is half of the 80px gap */
  }

  @media (max-width: 768px) {
    .brands-white-bar {
      margin-top: -50px;
      padding: 30px 0; /* Remove horizontal padding so container uses full width */
    }
    
    .marquee-track img {
      height: 70px; /* Much larger mobile height */
    }
    
    .marquee-track {
      gap: 50px; /* Adjusted gap for nicer mobile flow */
    }
    
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 25px)); } /* 25px is half of the 50px gap */
    }
  }
</style>

<div class="brands-section-wrapper">
  <div class="brands-bg-grid"></div>

  <div class="brands-container">
    <div class="brands-white-bar">
      <!-- Marquee Loop Container -->
      <div class="marquee-wrapper">
        <div class="marquee-track">
          <!-- ORIGINAL SET -->
          <img src="/wp-content/uploads/2019/06/tangit-logo.png" alt="Tangit" />
          <img src="/wp-content/uploads/2019/06/conexbanninger.png" alt="Conex Banninger" />
          <img src="/wp-content/uploads/2019/06/heliroma.png" alt="Heliroma" />
          <img src="/wp-content/uploads/2019/06/rems.png" alt="REMS" />
          <img src="/wp-content/uploads/2019/06/ridgid.png" alt="RIDGID" />
          <img src="/wp-content/uploads/2019/06/rothenberger.png" alt="Rothenberger" />
          
          <!-- DUPLICATED SET (Required to create the infinite seamless loop effect) -->
          <img src="/wp-content/uploads/2019/06/tangit-logo.png" alt="Tangit" />
          <img src="/wp-content/uploads/2019/06/conexbanninger.png" alt="Conex Banninger" />
          <img src="/wp-content/uploads/2019/06/heliroma.png" alt="Heliroma" />
          <img src="/wp-content/uploads/2019/06/rems.png" alt="REMS" />
          <img src="/wp-content/uploads/2019/06/ridgid.png" alt="RIDGID" />
          <img src="/wp-content/uploads/2019/06/rothenberger.png" alt="Rothenberger" />
        </div>
      </div>
    </div>
  </div>
</div>