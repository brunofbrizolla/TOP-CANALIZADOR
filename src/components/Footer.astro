<style>
  .footer {
    background-color: #0c1c2c;
    color: #ffffff;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    padding-top: 80px;
    border-top: 4px solid #ef4c37;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 40px;
    padding-bottom: 60px;
  }

  .footer-logo {
    max-height: 50px;
    margin-bottom: 25px;
    display: block;
  }

  .about-text {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 20px;
  }

  .widget-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 30px;
    position: relative;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .widget-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 40px;
    height: 3px;
    background-color: #ef4c37;
  }

  .widget-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .widget-links li {
    margin-bottom: 12px;
  }

  .widget-links a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .widget-links a:hover {
    color: #ef4c37;
    transform: translateX(5px);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
  }

  .contact-item.phone {
    text-decoration: none;
    color: #ffffff;
    font-weight: 700;
    font-size: 18px;
    transition: color 0.3s ease;
  }

  .contact-item.phone:hover {
    color: #ef4c37;
  }

  .contact-item .icon {
    color: #ef4c37;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .contact-item .text a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-item .text a:hover {
    color: #ef4c37;
  }

  .privacy-note {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 20px;
  }

  .footer-bottom {
    background-color: #08121d;
    padding: 30px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .copyright span {
    color: #ef4c37;
    font-weight: 600;
  }

  .bottom-branding a {
    color: #51acfb;
    text-decoration: none;
    font-weight: 600;
  }


  @media (max-width: 768px) {
    .container.mobile-column {
      flex-direction: column;
      gap: 15px;
      text-align: center;
    }
    
    .footer {
      padding-top: 60px;
    }

    .widget-title {
      margin-bottom: 20px;
    }
  }
</style>