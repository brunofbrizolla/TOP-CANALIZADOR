<style>
  /* Native Astro Slider implementation */
  .native-fade-slider {
    display: grid !important;
  }
  .native-fade-slider > .bt_bb_content_slider_item {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease-in-out, visibility 0.8s;
    pointer-events: none;
    z-index: 1;
  }
  .native-fade-slider > .bt_bb_content_slider_item.active {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto;
    z-index: 2;
  }
</style>
<script is:inline>
  function initSection3Slider() {
    const sliders = document.querySelectorAll('.native-fade-slider');
    console.log('Initializing Section 3 Sliders (Native):', sliders.length);
    
    sliders.forEach((slider) => {
      // Clear existing interval if any
      if (slider.dataset.sliderInterval) {
        clearInterval(parseInt(slider.dataset.sliderInterval));
      }
      
      const items = Array.from(slider.querySelectorAll('.bt_bb_content_slider_item'));
      if (items.length > 0) {
        let current = 0;
        
        // Setup initial state
        items.forEach((item, idx) => {
          item.classList.toggle('active', idx === 0);
          item.style.display = 'block';
        });
        
        const intervalId = setInterval(() => {
          items[current].classList.remove('active');
          current = (current + 1) % items.length;
          items[current].classList.add('active');
        }, 5000); // 5 seconds to match original feel
        
        slider.dataset.sliderInterval = intervalId.toString();
      }
    });
  }

  // Handle all lifecycle cases
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSection3Slider);
  } else {
    initSection3Slider();
  }
  
  document.addEventListener('astro:page-load', initSection3Slider);
  document.addEventListener('astro:after-swap', initSection3Slider);
</script>
