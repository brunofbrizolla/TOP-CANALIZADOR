    <script is:inline>
      // Smart Carousel Initialization
      (function() {
        function initCarousels() {
          if (window.innerWidth > 991) return;
          
          const carousels = document.querySelectorAll('.service-grid-container');
          
          carousels.forEach(container => {
            if (container.dataset.initialized) return;
            
            // 1. Add Arrows
            const prevBtn = document.createElement('div');
            prevBtn.className = 'carousel-nav-btn prev';
            prevBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>';
            
            const nextBtn = document.createElement('div');
            nextBtn.className = 'carousel-nav-btn next';
            nextBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>';
            
            // Inject arrows into the port or parent that has space
            const parent = container.parentElement;
            parent.style.position = 'relative';
            parent.appendChild(prevBtn);
            parent.appendChild(nextBtn);
            
            // 2. Scroll Logic
            const getScrollAmount = () => container.querySelector('.prof-service-box')?.offsetWidth + 15 || window.innerWidth * 0.9;
            
            prevBtn.onclick = (e) => {
              e.preventDefault();
              container.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
              resetAutoSlide();
            };
            
            nextBtn.onclick = (e) => {
              e.preventDefault();
              container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
              resetAutoSlide();
            };
            
            // 3. Auto-Slide
            let autoSlideInterval;
            
            function startAutoSlide() {
              autoSlideInterval = setInterval(() => {
                const maxScroll = container.scrollWidth - container.clientWidth;
                if (container.scrollLeft >= maxScroll - 50) {
                  container.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                  container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
                }
              }, 4000);
            }
            
            function resetAutoSlide() {
              clearInterval(autoSlideInterval);
              startAutoSlide();
            }
            
            startAutoSlide();
            
            // Pause on interaction
            container.addEventListener('touchstart', () => clearInterval(autoSlideInterval), { passive: true });
            container.addEventListener('mousedown', () => clearInterval(autoSlideInterval));
            
            container.dataset.initialized = "true";
          });
        }

        // Run on load
        if (document.readyState === 'complete') {
          initCarousels();
        } else {
          window.addEventListener('load', initCarousels);
        }
        
        // Re-check on resize for orientation changes
        window.addEventListener('resize', initCarousels);
      })();
    </script>



    <!-- Google Ads Click Tracking for Call & WhatsApp Buttons -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        const link = e.target.closest('a[href^="tel:"], a[href*="wa.me"], a[href*="whatsapp.com"]');
        if (link) {
          if (typeof gtag !== 'undefined') {
            const isWhatsApp = link.href.includes('wa.me') || link.href.includes('whatsapp');
            gtag('event', 'conversion', {
              'send_to': 'AW-735353172/vYsUCKen5J8cENSy0t4C',
              'event_label': isWhatsApp ? 'whatsapp_button_click' : 'call_button_click'
            });
          }
        }
      });
    </script>

